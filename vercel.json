{
  "buildCommand": null,
  "installCommand": null,
  "framework": null,
  "redirects": [
    { "source": "/prodotti-eccellenza.html", "destination": "/", "permanent": true },
    { "source": "/blog/il-bergamotto.html", "destination": "/", "permanent": true },
    { "source": "/blog/agrumi-alleati-salute.html", "destination": "/", "permanent": true },
    { "source": "/blog/cipolla-rossa-tropea.html", "destination": "/", "permanent": true },
    { "source": "/blog/olio-extravergine-artigianale.html", "destination": "/", "permanent": true },
    { "source": "/blog/marmellata-di-limone.html", "destination": "/", "permanent": true },
    { "source": "/blog/finocchietto-selvatico-calabria.html", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
